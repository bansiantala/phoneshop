@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Admin</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        body {
            background: #141e30;
            color: white;
            font-family: 'Segoe UI';
        }

        nav a {
            color: #ff7f50;
            margin-right: 15px;
            text-decoration: none;
            font-weight: 500;
        }

            nav a:hover {
                color: #ff6347;
            }

        .container {
            padding: 20px;
        }

        .btn-orange {
            background: #ff7f50;
            color: white;
            padding: 6px 12px;
            border: none;
            border-radius: 8px;
        }

            .btn-orange:hover {
                background: #ff6347;
            }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        th, td {
            padding: 8px;
            border-bottom: 1px solid #444;
        }
    </style>
</head>
<body>
    <nav>
        <a asp-action="Dashboard" asp-controller="Admin">Dashboard</a>
        <a asp-action="Users" asp-controller="Admin">Users</a>
        <a asp-action="Products" asp-controller="Admin">Products</a>
        <a asp-action="Orders" asp-controller="Admin">Orders</a>
        <a asp-action="Logout" asp-controller="Admin">Logout</a>
    </nav>

    <div class="container">
        @RenderBody()
    </div>

    @RenderSection("Scripts", required: false)
</body>
</html>