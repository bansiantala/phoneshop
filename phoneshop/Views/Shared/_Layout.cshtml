<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PhoneMart</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />


</head>
<body>

    <!-- ================= NAVBAR ================= -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">

            <a class="navbar-brand fw-bold text-warning" asp-controller="Home" asp-action="Index">
                 PhoneMart
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">

                <!-- Search Bar -->
                <form class="d-flex mx-auto w-50">
                    <input class="form-control me-2 rounded-pill" type="search" placeholder="Search smartphones...">
                    <button class="btn btn-warning rounded-pill">Search</button>
                </form>

                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Home" asp-action="Index">Home</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white" href="/About">About</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/Contact">Contact</a>
                    </li>


                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Product" asp-action="Index">
                            Product
                        </a>
                    </li>


                    <li class="nav-item">
                        <a class="nav-link text-white position-relative"  asp-action="order" asp-controller="Product">Order</a>
                    </li>


                    <li class="nav-item">
                        <a class="nav-link text-white position-relative" asp-controller="Product" asp-action="Cart">
                            Cart
                                                   </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Account" asp-action="Login">Login</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Account" asp-action="Register">Register</a>
                    </li>


                </ul>

            </div>
        </div>
    </nav>


    
                       
    




    
    <!-- ================= MAIN CONTENT ================= -->
    <div class="container mt-5">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- ================= FOOTER ================= -->
    <footer class="bg-dark text-white text-center p-4 mt-5">
        <p class="mb-1 fw-bold">PhoneMart</p>
        <small>© 2026 PhoneMart. All Rights Reserved.</small>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>