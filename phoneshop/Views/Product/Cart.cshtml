@model List<phoneshop.Models.CartItem>

<h2 class="text-center mt-4">Shopping Cart</h2>

<div class="container mt-4">

    <table class="table table-bordered text-center">

        <thead class="table-dark">
            <tr>
                <th>Image</th>
                <th>Name</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Total</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td>
                        <img src="@item.Product.Image" width="80" />
                    </td>

                    <td>@item.Product.Name</td>

                    <td>₹@item.Product.Price</td>

                    <td>

                        <a asp-action="DecreaseQty"
                           asp-route-id="@item.Product.Id"
                           class="btn btn-danger btn-sm">-</a>

                        <span class="mx-2">@item.Quantity</span>

                        <a asp-action="IncreaseQty"
                           asp-route-id="@item.Product.Id"
                           class="btn btn-success btn-sm">+</a>

                    </td>

                    <td>
                        ₹@(item.Product.Price* item.Quantity)
                    </td>

                    <td>
                        <a asp-action="RemoveFromCart"
                           asp-route-id="@item.Product.Id"
                           class="btn btn-warning btn-sm">
                            Remove
                        </a>
                    </td>

                </tr>
            }

        </tbody>

    </table>

    <h4 class="text-end">
        Total :
        ₹@Model.Sum(x => x.Product.Price * x.Quantity)
    </h4>

    <div class="text-end">

        <a asp-action="Checkout" class="btn btn-success">
            Proceed to Checkout
        </a>

    </div>

</div>