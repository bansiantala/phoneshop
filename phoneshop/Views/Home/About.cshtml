@{
    ViewData["Title"] = "About";
}

<!-- ===== HERO SECTION ===== -->
<section class="about-hero py-4" style="background: linear-gradient(135deg, #141e30, #243b55);">
    <div class="container text-center text-white">
        <h1 class="display-5 fw-bold mb-2">About PhoneMart</h1>
        <p class="lead mb-3">
            Your trusted destination for premium smartphones from
            <strong>Apple</strong>, <strong>Samsung</strong>, and <strong>Google</strong>.
        </p>
    </div>
</section>

<!-- ===== IMAGE + TEXT SECTION ===== -->
<section class="about-content py-4" style="background: linear-gradient(135deg, #141e30, #243b55);">
    <div class="container">

        <div class="row align-items-center mb-4">
            <div class="col-lg-6 mb-3 mb-lg-0 text-center">
                <img src="~/images/about.jpg"
                     class="img-fluid rounded-4 shadow-sm about-img"
                     alt="PhoneShop Smartphone" />
            </div>
            <div class="col-lg-6 text-white">
                <h2 class="fw-bold mb-2">Why Choose Us?</h2>
                <p class="mb-3">
                    At <strong>PhoneMart</strong>, we provide 100% genuine products,
                    best price guarantee, and fast delivery across India.
                </p>
                <ul class="list-unstyled mb-0">
                    <li class="mb-1"> Premium Brand Collection</li>
                    <li class="mb-1">Secure Payment System</li>
                    <li class="mb-1"> Easy Returns & Warranty</li>
                    <li class="mb-1"> 24/7 Customer Support</li>
                </ul>
            </div>
        </div>

        <!-- ===== FEATURE CARDS ===== -->
        <div class="row text-center g-3">

            <div class="col-md-4">
                <div class="about-card p-3 rounded-3 shadow-sm h-100 bg-light">
                    <h5 class="fw-bold mb-1">Fast Delivery</h5>
                    <p class="text-muted mb-0">Lightning fast shipping anywhere in India.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="about-card p-3 rounded-3 shadow-sm h-100 bg-light">
                    <h5 class="fw-bold mb-1">Secure Payment</h5>
                    <p class="text-muted mb-0">Safe & encrypted online transactions.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="about-card p-3 rounded-3 shadow-sm h-100 bg-light">
                    <h5 class="fw-bold mb-1">Genuine Products</h5>
                    <p class="text-muted mb-0">100% original brand smartphones with warranty.</p>
                </div>
            </div>

        </div>

    </div>
</section>

<!-- ===== CUSTOM CSS ===== -->
<style>
    .about-hero h1 {
        letter-spacing: 1px;
    }

    .about-hero p {
        font-size: 1rem;
    }

    .about-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15);
        transition: all 0.3s ease;
    }

    .about-img {
        max-height: 250px; 
        width: auto;
    }
</style>